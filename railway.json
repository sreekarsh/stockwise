{
  "version": "2",
  "builds": [
    {
      "src": "Dockerfile",
      "use": "railway:buildpack-docker"
    }
  ],
  "deploy": {
    "startCommand": "sh -c 'npx prisma migrate deploy && node dist/server.js'",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}