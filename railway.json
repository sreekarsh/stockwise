{
  "version": "2",
  "builds": [
    {
      "src": "stockwise-fullstack/stockwise/server.ts",
      "use": "@railway/node"
    }
  ],
  "deploy": {
    "startCommand": "npx tsx stockwise-fullstack/stockwise/server.ts",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}