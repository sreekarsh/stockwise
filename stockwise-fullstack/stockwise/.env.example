# StockWise Environment Configuration
# WARNING: Never commit this file. Copy as .env and fill in real values.

SESSION_SECRET=stockwise_secure_secret_key_2025_production_change_me_please_use_a_random_string_here
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password
COINGECKO_API_KEY=CG-your-api-key-here
FINNHUB_API_KEY=your-finnhub-key-here
NODE_ENV=development
PORT=3000
ML_PORT=8100

# Database — use ?pgbouncer=true when connecting through PgBouncer
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockwise?schema=public

# PgBouncer connection URL (for production)
# DATABASE_URL=postgresql://postgres:postgres@localhost:6432/stockwise?schema=public&pgbouncer=true&connection_limit=20

REDIS_URL="redis://localhost:6379"
ENCRYPTION_MASTER_KEY="your-64-char-hex-string-here"
DOMAIN="stockwise.example.com"
CRYPTOCOMPARE_API_KEY="your-cryptocompare-key-here"
SENTRY_DSN=""

# OpenAI API Key (for AI Coach — GPT-4o)
OPENAI_API_KEY=sk-your-key-here

# Backup to S3-compatible storage (optional)
# BACKUP_S3_BUCKET=stockwise-backups
# BACKUP_S3_ENDPOINT=s3.amazonaws.com
# BACKUP_S3_ACCESS_KEY=your-access-key
# BACKUP_S3_SECRET_KEY=your-secret-key

# HashiCorp Vault for secrets management (optional)
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=hvs.your-token-here

# MLflow tracking for model registry (optional)
# MLFLOW_TRACKING_URI=http://localhost:5000
