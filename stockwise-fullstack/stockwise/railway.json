{
  "version": "2",
  "builds": [
    {
      "src": "server.ts",
      "use": "@railway/node"
    },
    {
      "src": "ml_engine/server.py",
      "use": "@railway/python"
    }
  ],
  "deploy": {
    "startCommand": "npx tsx server.ts",
    "healthcheckPath": "/api/markets?per_page=1",
    "healthcheckTimeout": 30,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}
